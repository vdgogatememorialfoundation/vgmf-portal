generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER") // ADMIN, STAFF, DOCTOR, JUDGE, REVIEWER, TRUSTEE, APPLICANT, USER, SCANNER
  category      String?   // DOCTOR, STUDENT, RESEARCHER, PATIENT, GENERAL, INSTITUTION
  phone         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  dob           DateTime?
  gender        String?
  loginMethod   String   @default("password") // password, otp
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  seminarRegs   SeminarRegistration[]
  fellowshipApps FellowshipApplication[]
  autismRegs    AutismRegistration[]
  eventRegistrations EventRegistration[]
  supportTickets    Ticket[]
  certificates      Certificate[]
  competitions      Competition[]
  identityVerifications IdentityVerification[]
  addresses         UserAddress[]
  paymentMethods    PaymentMethod[]
  formSubmissions   EventFormSubmission[]
  paymentReceipts   PaymentReceipt[]
  refunds           Refund[]
  casePresentations CasePresentation[]
  judgeScores       JudgeScore[]
  competitionEntries CompetitionEntry[]
  scanLogs          ScanLog[]
  chatSessions      ChatSession[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String?
  shortDesc       String?
  sku             String?
  price           Float
  compareAtPrice  Float?
  costPrice       Float?
  stockQuantity   Int              @default(0)
  lowStockThreshold Int            @default(10)
  isPublished     Boolean          @default(false)
  isFeatured      Boolean          @default(false)
  weight          Float?
  categoryId      String
  category        ProductCategory  @relation(fields: [categoryId], references: [id])
  thumbnailUrl    String?
  hsnCode         String?
  gstPercentage   Float            @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  images          ProductImage[]
  orderItems      OrderItem[]
}

model ProductCategory {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  description String?
  parentId String?
  parent   ProductCategory? @relation("CategoryParent", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryParent")
  sortOrder Int      @default(0)
  isActive Boolean   @default(true)
  products Product[]
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl  String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
}

model Order {
  id                String      @id @default(uuid())
  orderNumber       String      @unique
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  status            String      @default("PENDING") // PENDING, CONFIRMED, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  subTotal          Float
  discount          Float       @default(0)
  shippingCost      Float       @default(0)
  tax               Float       @default(0)
  totalAmount       Float
  shippingName      String?
  shippingAddress1  String?
  shippingAddress2  String?
  shippingCity      String?
  shippingState     String?
  shippingPinCode   String?
  shippingPhone     String?
  notes             String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  shiprocketOrderId String?
  shiprocketShipmentId String?
  trackingUrl       String?
  estimatedDelivery DateTime?
  actualDeliveryDate DateTime?
  cancelledAt       DateTime?
  orderDate         DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  items             OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  totalPrice Float
}

model SeminarRegistration {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  ticketNumber   String   @unique
  phoneNumber    String?
  organization   String?
  designation    String?
  isVerified     Boolean  @default(false)
  isCancelled    Boolean  @default(false)
  paymentStatus  String?
  registrationDate DateTime @default(now())
  createdAt      DateTime @default(now())
}

model FellowshipApplication {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  trackingNumber  String   @unique
  applicationId   String?  @unique  // 12-digit
  status          String   @default("SUBMITTED") // DRAFT, SUBMITTED, UNDER_REVIEW, SHORTLISTED, INTERVIEW_SCHEDULED, SELECTED, REJECTED, FUNDED
  fullName        String?
  email           String?
  phoneNumber     String?
  areaOfInterest  String?
  statementOfPurpose String?
  education       String?
  institution     String?
  experienceYears Int?
  experience      String?
  researchProposal String?
  preferredMentor String?
  rejectionReason String?
  adminNotes      String?
  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
  documents       FellowshipDocument[]
}

model FellowshipDocument {
  id            String   @id @default(uuid())
  applicationId String
  application   FellowshipApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  documentName  String
  documentType  String?
  documentUrl   String
  fileSize      Int?
  createdAt     DateTime @default(now())
}

model AutismRegistration {
  id               String   @id @default(uuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id])
  childName        String
  childAge         Int?
  childGender      String?
  parentName       String?
  phoneNumber      String?
  alternatePhone   String?
  email            String?
  address          String?
  city             String?
  state            String?
  pinCode          String?
  diagnosisDetails String?
  therapyHistory   String?
  specialRequirements String?
  eTicketNumber    String   @unique
  isPreRegistered  Boolean  @default(false)
  isFullyRegistered Boolean @default(false)
  isVerified       Boolean  @default(false)
  competitionCategory String?
  competitionEntryStatus String?
  registrationDate DateTime @default(now())
  completionDate   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Article {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  content      String?
  excerpt      String?
  coverImageUrl String?
  authorId     String?
  authorName   String?
  category     String?
  tags         String?
  isPublished  Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  viewCount    Int      @default(0)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String?
  summary   String?
  imageUrl  String?
  linkUrl   String?
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  isPinned  Boolean  @default(false)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  adminReply String?
  repliedAt DateTime?
  createdAt DateTime @default(now())
}

model SiteContent {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  contentType String?  @default("text")
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ChatSession {
  id           String       @id @default(uuid())
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  title        String       @default("New Chat")
  isActive     Boolean      @default(true)
  isResolved   Boolean      @default(false)
  lastMessageAt DateTime?
  createdAt    DateTime     @default(now())
  messages     ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  content   String
  isFromUser Boolean    @default(true)
  messageType String?   @default("text")
  timestamp DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String?
  type      String?
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MaintenanceSetting {
  id         String    @id @default(uuid())
  isEnabled  Boolean   @default(false)
  message    String?
  allowedIps String?
  endTime    DateTime?
  updatedAt  DateTime  @updatedAt
  createdAt  DateTime  @default(now())
}

model OtpRecord {
  id        String   @id @default(uuid())
  email     String
  code      String
  action    String   @default("signup") // signup, login, reset
  expires   DateTime
  verified  Boolean  @default(false)
  sentAt    DateTime @default(now())
  attempts  Int      @default(0)
  @@index([email, action])
}

model SiteSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  group       String   @default("general") // general, auth, payment, email, appearance
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model SiteReview {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  rating       Int
  title        String?
  content      String?
  category     String?  // GENERAL, SEMINAR, FELLOWSHIP, AUTISM
  isApproved   Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model EmailLog {
  id        String   @id @default(uuid())
  userId    String?
  toEmail   String
  subject   String
  type      String   // OTP, WELCOME, REGISTRATION, PAYMENT, CERTIFICATE, TICKET, STATUS_CHANGE, CANCELLATION
  status    String   @default("SENT") // SENT, FAILED, BOUNCED
  relatedId String?
  relatedType String?
  error     String?
  sentAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // LOGIN, LOGOUT, CREATE_ACCOUNT, UPDATE_PROFILE, REGISTER_EVENT, CANCEL_REGISTRATION, PAYMENT, ADMIN_ACTION
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model EventFormField {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fieldName   String
  fieldType   String   @default("text") // text, email, tel, date, select, textarea, file, number, checkbox
  label       String
  placeholder String?
  required    Boolean  @default(false)
  options     String?  // JSON array for select fields
  validation  String?  // JSON validation rules
  sortOrder   Int      @default(0)
  section     String?  // Grouping: "personal", "professional", "address", "documents"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model EventFormSubmission {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  formData       Json     // Stores all form field values as JSON
  status         String   @default("SUBMITTED") // DRAFT, SUBMITTED, UNDER_REVIEW, APPROVED, REJECTED
  ticketNumber   String?  @unique
  eTicketUrl     String?
  paymentStatus  String?  // NONE, PENDING, COMPLETED, REFUNDED
  paymentAmount  Float?
  razorpayOrderId   String?
  razorpayPaymentId String?
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model SiteNotice {
  id          String    @id @default(uuid())
  title       String
  content     String?
  noticeType  String    @default("info") // info, warning, urgent, promo
  position    String    @default("below-header") // below-header, above-hero, popup
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  eventNotices EventNotice[]
}

model Event {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String?
  shortDesc    String?
  eventDate    DateTime
  endDate      DateTime?
  location     String?
  city         String?
  address      String?
  eventType    String   // Seminar, Fellowship, Autism, Competition, Workshop, Guest Lecture
  isPublished  Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  maxAttendees Int?
  ticketPrice  Float?
  bannerUrl    String?
  imageUrl     String?
  contactEmail      String?
  contactPhone      String?
  restrictToDoctors Boolean  @default(false)
  hasForm           Boolean  @default(false)
  formTitle         String?
  formDescription   String?
  requiresPayment   Boolean  @default(false)
  allowMultipleRegistrations Boolean @default(false)
  registrationStartDate DateTime?
  registrationDeadline    DateTime?
  cancellationDeadline    DateTime?
  cancellationFee         Float?
  refundPercentage        Int?
  showCountdown           Boolean  @default(false)
  isRegistrationOpen      Boolean  @default(true)
  isCancellationEnabled   Boolean  @default(false)
  isPastEvent             Boolean  @default(false)
  displayedList           Boolean  @default(false) // candidate list displayed
  judgeDeadline           DateTime?
  reviewerDeadline        DateTime?
  trusteeDeadline         DateTime?
  formPreviewUrl          String?
  requiresIdentityVerification Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  formFields        EventFormField[]
  formSubmissions   EventFormSubmission[]
  registrations     EventRegistration[]
  schedules         EventSchedule[]
  casePresentations CasePresentation[]
  judgeScores       JudgeScore[]
  competitionEntries CompetitionEntry[]
  scanLogs          ScanLog[]
  eventProducts     EventProduct[]
  eventSales        EventSale[]
  eventNotices      EventNotice[]
}

model EventNotice {
  id        String     @id @default(uuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  noticeId  String
  notice    SiteNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  @@unique([eventId, noticeId])
}

model EventRegistration {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  ticketNumber   String   @unique
  applicationId  String?  @unique  // 12-digit e.g. VGF2026000001
  formData       Json?
  status         String   @default("SUBMITTED") // SUBMITTED, APPROVED, REJECTED, CANCELLED
  paymentStatus  String?  // NONE, PENDING, COMPLETED, REFUNDED
  paymentAmount  Float?
  isVerified     Boolean  @default(false)
  eTicketNumber  String?
  eTicketUrl     String?
  isCancelled    Boolean  @default(false)
  cancelledAt    DateTime?
  cancellationReason String?
  refundAmount   Float?
  refundStatus   String?  // NONE, PENDING, PROCESSED, REJECTED
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  registrationDate DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  scanLogs       ScanLog[]
}

model Ticket {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  subject        String
  description    String?
  category       String   @default("GENERAL") // GENERAL, TECHNICAL, PAYMENT, REGISTRATION, OTHER
  priority       String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status         String   @default("OPEN") // OPEN, IN_PROGRESS, WAITING, RESOLVED, CLOSED
  relatedType    String?  // EVENT, ORDER, FELLOWSHIP, SEMINAR, AUTISM
  relatedId      String?
  adminReply     String?
  repliedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Certificate {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  title          String
  description    String?
  certificateType String  @default("PARTICIPATION") // PARTICIPATION, COMPLETION, ACHIEVEMENT, MERIT
  eventTitle     String?
  issuedDate     DateTime @default(now())
  expiryDate     DateTime?
  certificateUrl String?
  certificateNumber String @unique
  verificationCode  String @unique  // For public verification
  status         String   @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED
  createdAt      DateTime @default(now())
}

model Competition {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  eventId        String?
  title          String
  category       String   // ART, ESSAY, VIDEO, PRESENTATION, OTHER
  description    String?
  fileUrl        String?
  status         String   @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, SHORTLISTED, WINNER, RUNNER_UP, PARTICIPANT
  score          Float?
  feedback       String?
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model PortalLink {
  id          String   @id @default(uuid())
  portalName  String   @unique
  urlPath     String
  description String?
  isActive    Boolean  @default(true)
  requiredRole String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserRole {
  id          String   @id @default(uuid())
  roleName    String   @unique
  description String?
  permissions Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageConfig {
  id           String   @id @default(uuid())
  path         String   @unique
  title        String
  description  String?
  isEnabled    Boolean  @default(true)
  requiredRoles String[] @default([])
  showInMenu   Boolean  @default(true)
  menuLabel    String?
  menuIcon     String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IdentityVerification {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  eventId         String?
  event           Event?   @relation(fields: [eventId], references: [id])
  documentType    String
  documentNumber  String?
  documentUrl     String?
  selfieUrl       String?
  status          String   @default("PENDING")
  rejectionReason String?
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UserAddress {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label        String   @default("Home") // Home, Work, Other
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  country      String   @default("India")
  isDefault    Boolean  @default(false)
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PaymentMethod {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // UPI, Card, NetBanking, Wallet
  last4        String?  // Last 4 digits for cards
  provider     String?  // Visa, Mastercard, Paytm, etc.
  upiId        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model PaymentReceipt {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  receiptNumber  String   @unique
  relatedType    String   // EVENT, ORDER, FELLOWSHIP
  relatedId      String?
  amount         Float
  tax            Float    @default(0)
  totalAmount    Float
  paymentMethod  String?
  razorpayPaymentId String?
  status         String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, REFUNDED
  receiptUrl     String?
  issuedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
}

model Refund {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  relatedType    String   // EVENT, ORDER
  relatedId      String?
  amount         Float
  reason         String?
  status         String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, REJECTED
  refundMethod   String?  // Original, Bank Transfer, UPI
  processedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model EventSchedule {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime?
  speaker     String?
  location    String?
  track       String?  // Main Hall, Room A, Virtual, etc.
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model CasePresentation {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  topic          String
  description    String?
  videoUrl       String?
  pptUrl         String?
  pdfUrl         String?
  status         String   @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, SCORED, SHORTLISTED
  totalScore     Float?
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  scores         JudgeScore[]
}

model JudgeScore {
  id               String   @id @default(uuid())
  casePresentationId String?
  casePresentation CasePresentation? @relation(fields: [casePresentationId], references: [id], onDelete: Cascade)
  competitionEntryId String?
  competitionEntry CompetitionEntry? @relation(fields: [competitionEntryId], references: [id], onDelete: Cascade)
  judgeId          String
  judge            User     @relation(fields: [judgeId], references: [id])
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id])
  scientificMerit  Float?
  innovation       Float?
  feasibility      Float?
  presentation     Float?
  relevance        Float?
  totalScore       Float?
  feedback         String?
  scoredAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CompetitionEntry {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  title          String
  category       String   // ART, ESSAY, VIDEO, PRESENTATION, OTHER
  description    String?
  fileUrls       String?  // JSON array of file URLs
  status         String   @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, SHORTLISTED, WINNER, RUNNER_UP, PARTICIPANT
  totalScore     Float?
  feedback       String?
  submittedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  scores         JudgeScore[]
}

model ScanLog {
  id             String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id])
  registrationId String?
  registration   EventRegistration? @relation(fields: [registrationId], references: [id])
  ticketNumber   String
  scannedBy      String
  scanner        User     @relation(fields: [scannedBy], references: [id])
  status         String   @default("VALID") // VALID, ALREADY_SCANNED, INVALID, CANCELLED
  scannedAt      DateTime @default(now())
}

model EventProduct {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  stockQty   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model EventSale {
  id           String   @id @default(uuid())
  eventId      String
  event        Event   @relation(fields: [eventId], references: [id])
  sellerId     String
  buyerName    String
  buyerPhone   String?
  buyerEmail   String?
  totalAmount  Float
  itemsJson    Json
  paymentMethod String  @default("CASH")
  receiptNumber String @unique
  soldAt       DateTime @default(now())
  createdAt    DateTime @default(now())
}
